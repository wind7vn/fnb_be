# ==========================================
# SERVER CONFIGURATION
# ==========================================
PORT=8080
ENV=development # development | staging | production
APP_NAME=fnb_multi_tenant

# ==========================================
# DATABASE (PostgreSQL)
# ==========================================
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=secret
DB_NAME=fnb_db
DB_SSLMODE=disable
DB_MAX_IDLE_CONNS=10
DB_MAX_OPEN_CONNS=100

# ==========================================
# CACHE & PUBSUB (Redis)
# ==========================================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ==========================================
# AUTHENTICATION (JWT)
# ==========================================
JWT_SECRET=super_secret_key_change_in_production
JWT_EXPIRE_MINUTES=1440 # 24 hours
JWT_REFRESH_EXPIRE_DAYS=7

# ==========================================
# PUSH NOTIFICATION (Firebase/FCM / APNS)
# ==========================================
# APNS_KEY_PATH=./secrets/AuthKey_12345.p8
# APNS_KEY_ID=123ABC456
# APNS_TEAM_ID=DEF789GHI

# ==========================================
# MISCELLANEOUS / EXTERNAL APIs
# ==========================================
# AWS_S3_BUCKET=fnb-media-bucket
# STRIPE_API_KEY=sk_test_xxx
